{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catie.io/schemas/bug-report-v1.json",
  "title": "Catie Bug Report Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "event_id",
    "occurred_at",
    "app",
    "reporter",
    "bug",
    "context"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "catie.bug_report.v1"
    },
    "event_type": {
      "type": "string",
      "const": "bug_report.submitted"
    },
    "event_id": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "app": {
      "type": "object",
      "required": ["product_name", "package_name", "version"],
      "properties": {
        "product_name": { "type": "string" },
        "package_name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "reporter": {
      "type": "object",
      "required": ["username", "email"],
      "properties": {
        "username": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"] }
      }
    },
    "bug": {
      "type": "object",
      "required": ["title", "description", "steps_to_reproduce", "severity"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "steps_to_reproduce": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_behavior": { "type": ["string", "null"] },
        "actual_behavior": { "type": ["string", "null"] },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        }
      }
    },
    "context": {
      "type": "object",
      "required": [
        "selected_subject",
        "selected_topics",
        "question_count",
        "active_tab",
        "status",
        "is_authenticated",
        "is_dev_mode",
        "app_zoom",
        "preview_visible",
        "streaming_chars",
        "user_agent",
        "captured_at"
      ],
      "properties": {
        "selected_subject": { "type": ["string", "null"] },
        "selected_topics": { "type": "array", "items": { "type": "string" } },
        "question_count": { "type": "integer", "minimum": 0 },
        "active_tab": { "type": "string", "enum": ["generate", "bank"] },
        "status": { "type": "string" },
        "is_authenticated": { "type": "boolean" },
        "is_dev_mode": { "type": "boolean" },
        "app_zoom": { "type": "number" },
        "preview_visible": { "type": "boolean" },
        "streaming_chars": { "type": "integer", "minimum": 0 },
        "user_agent": { "type": "string" },
        "captured_at": { "type": "string", "format": "date-time" }
      }
    },
    "diagnostics": {
      "type": ["object", "null"],
      "properties": {
        "os": { "type": "string" },
        "arch": { "type": "string" },
        "is_dev_mode": { "type": "boolean" },
        "in_memory_question_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
